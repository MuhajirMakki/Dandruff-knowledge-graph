@prefix ex: <http://example.org/biomedical_kg/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix res: <http://example.org/biomedical_kg/resource/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:BiomedicalKnowledgeGraph a owl:Ontology ;
    rdfs:label "Biomedical Knowledge Graph" .

ex:activates a owl:ObjectProperty ;
    rdfs:label "activates" .

ex:associated_with a owl:ObjectProperty ;
    rdfs:label "associated_with" .

ex:breaks_down a owl:ObjectProperty ;
    rdfs:label "breaks_down" .

ex:causes a owl:ObjectProperty ;
    rdfs:label "causes" .

ex:damages a owl:ObjectProperty ;
    rdfs:label "damages" .

ex:inhibits a owl:ObjectProperty ;
    rdfs:label "inhibits" .

ex:produces a owl:ObjectProperty ;
    rdfs:label "produces" .

ex:protects a owl:ObjectProperty ;
    rdfs:label "protects" .

ex:related_to a owl:ObjectProperty ;
    rdfs:label "related_to" .

res:Aspergillus a ex:Microorganism,
        owl:NamedIndividual ;
    rdfs:label "Aspergillus" ;
    ex:associated_with res:Fungal_Infection ;
    ex:associated_with_relation "associated_with" ;
    ex:associated_with_source 5052 ;
    ex:related_to res:Fungal_Infection ;
    ex:type "Microorganism" .

