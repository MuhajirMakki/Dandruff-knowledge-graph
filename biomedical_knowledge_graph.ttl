ex:treats a owl:ObjectProperty ;
    rdfs:label "treats" .

ex:Biological_Structure a owl:Class ;
    rdfs:label "Biological Structure" .

ex:Chemical a owl:Class ;
    rdfs:label "Chemical" .

ex:Enzyme a owl:Class ;
    rdfs:label "Enzyme" .

ex:Process a owl:Class ;
    rdfs:label "Process" .

ex:Substance a owl:Class ;
    rdfs:label "Substance" .

ex:Symptom a owl:Class ;
    rdfs:label "Symptom" .

res:Cytochrome_P450 a ex:Biological_Structure,
        owl:NamedIndividual ;
    rdfs:label "Cytochrome P450" ;
    ex:type "Biological Structure" .

res:Dna_Replication a ex:Biological_Process,
        owl:NamedIndividual ;
    rdfs:label "Dna Replication" ;
    ex:type "Biological Process" .

res:Flaking a ex:Symptom,
        owl:NamedIndividual ;
    rdfs:label "Flaking" ;
    ex:type "Symptom" .

res:Fungal_Infection a ex:Disease,
        owl:NamedIndividual ;
    rdfs:label "Fungal Infection" ;
